<header class="hero">
  <canvas id="hero-canvas" aria-hidden="true"></canvas>
  <div class="hero-veil" aria-hidden="true"></div>
  <div class="hero-inner">
    <p class="hero-eyebrow">A self-study project in pure math</p>
    <h1>Complex Analysis, <span class="grad-text">Visually</span></h1>
    <p class="hero-tagline">Every theorem paired with an interactive visualization you can drag, deform, and step through — built from first principles, in order, as I learn them.</p>
    <div class="hero-ctas">
      <a class="btn btn-primary" href="/visualizations/">Explore the visualizations &rarr;</a>
      <a class="btn btn-ghost" href="/lessons/00-big-picture-overview/">Start with Lesson 0</a>
    </div>
    <p class="hero-caption">The background is live domain coloring — each point z is colored by arg&nbsp;f(z) for a rational function whose zero is drifting around the plane. Lesson 0 explains how to read it.</p>
  </div>
  <script>
    (function () {
      const cv = document.getElementById("hero-canvas");
      if (!cv || !cv.getContext) return;
      const ctx = cv.getContext("2d");
      const W = 192, H = 108;
      cv.width = W; cv.height = H;
      const img = ctx.createImageData(W, H);
      const d = img.data;

      function hslToRgb(h, s, l) {
        h = ((h % 360) + 360) % 360;
        const c = (1 - Math.abs(2 * l - 1)) * s;
        const x = c * (1 - Math.abs(((h / 60) % 2) - 1));
        const m = l - c / 2;
        let r, g, b;
        if (h < 60) { r = c; g = x; b = 0; }
        else if (h < 120) { r = x; g = c; b = 0; }
        else if (h < 180) { r = 0; g = c; b = x; }
        else if (h < 240) { r = 0; g = x; b = c; }
        else if (h < 300) { r = x; g = 0; b = c; }
        else { r = c; g = 0; b = x; }
        return [(r + m) * 255, (g + m) * 255, (b + m) * 255];
      }

      // Domain coloring of f(z) = (z^2 - 1)(z - c(t)) / (z^2 + 2 + 2i),
      // with the zero c(t) drifting on a slow Lissajous path. Hue = arg f(z);
      // lightness bands follow log|f(z)| (contours of constant modulus).
      function frame(t) {
        const cx = 0.7 * Math.cos(t * 0.00031);
        const cy = 0.7 * Math.sin(t * 0.00043);
        let i = 0;
        for (let py = 0; py < H; py++) {
          for (let px = 0; px < W; px++) {
            const re = (px / W - 0.5) * 5.4;
            const im = (py / H - 0.5) * 3.1;
            const zr = re * re - im * im, zi = 2 * re * im;
            const ar = zr - 1, ai = zi;
            const br = re - cx, bi = im - cy;
            const nr = ar * br - ai * bi, ni = ar * bi + ai * br;
            const dr = zr + 2, di = zi + 2;
            const dd = dr * dr + di * di + 1e-9;
            const fr = (nr * dr + ni * di) / dd, fi = (ni * dr - nr * di) / dd;
            const arg = Math.atan2(fi, fr);
            const mod2 = fr * fr + fi * fi;
            const hue = arg * 57.29578 + t * 0.008;
            const band = 0.5 + 0.5 * Math.cos(3.1416 * Math.log(mod2 + 1e-12) * 0.7213);
            const rgb = hslToRgb(hue, 0.65, 0.24 + 0.2 * band);
            d[i++] = rgb[0]; d[i++] = rgb[1]; d[i++] = rgb[2]; d[i++] = 255;
          }
        }
        ctx.putImageData(img, 0, 0);
      }

      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        frame(0);
        return;
      }
      let last = 0;
      function loop(t) {
        if (t - last > 50) { frame(t); last = t; }
        requestAnimationFrame(loop);
      }
      requestAnimationFrame(loop);
    })();
  </script>
</header>
