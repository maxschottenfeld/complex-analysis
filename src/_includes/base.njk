<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {%- set pageTitle = title + " — Complex Analysis" %}
  {%- if page.url == "/" %}{% set pageTitle = title %}{% endif %}
  <title>{{ pageTitle }}</title>
  {%- if description %}
  <meta name="description" content="{{ description }}">
  <meta property="og:description" content="{{ description }}">
  {%- endif %}
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:type" content="{% if page.url == '/' %}website{% else %}article{% endif %}">
  <meta property="og:site_name" content="Complex Analysis, Visually">
  <meta property="og:image" content="https://maxschottenfeld.github.io/complex-analysis/assets/images/og-banner.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:image" content="https://maxschottenfeld.github.io/complex-analysis/assets/images/og-banner.png">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='18' fill='%230a0c12'/%3E%3Ctext x='50' y='74' font-size='68' text-anchor='middle' font-family='Georgia,serif' fill='hsl(215 70%25 70%25)'%3E%26%238450%3B%3C/text%3E%3C/svg%3E">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400..600;1,6..72,400..600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400..700;1,8..60,400..600&display=swap">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
  <script defer>
    document.addEventListener("DOMContentLoaded", function () {
      renderMathInElement(document.body, {
        delimiters: [
          { left: "$$", right: "$$", display: true },
          { left: "$", right: "$", display: false }
        ],
        // \htmlClass carries term tags in proof-stepper math (pf-* spans)
        trust: function (ctx) { return ctx.command === "\\htmlClass"; },
        strict: function (errorCode) { return errorCode === "htmlExtension" ? "ignore" : "warn"; }
      });
    });
  </script>
  {% if scrolly %}<script defer src="/js/scrolly.js"></script>{% endif %}
  {% if proofstepper %}<script defer src="/js/proof-stepper.js"></script>{% endif %}
  {% if '/lessons/' in page.url %}<script defer src="/js/page-tracker.js"></script>{% endif %}
</head>
<body{% if hue %} style="--h: {{ hue }}"{% endif %}>
  <nav class="site-nav">
    <div class="nav-inner">
      <a class="brand" href="/"><span class="brand-mark">&#8450;</span>Complex Analysis</a>
      <div class="nav-links">
        <a class="nav-link" href="/lessons/">Lessons</a>
        <a class="nav-link" href="/visualizations/">Visualizations</a>
        <a class="nav-link" href="/how-i-built-this/">How I built this</a>
        <a class="nav-link" href="https://github.com/maxschottenfeld/complex-analysis" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </nav>
  {% if hero %}{% include "hero.njk" %}{% endif %}
  <main{% if wide %} class="wide"{% endif %}>
    {{ content | safe }}
    {% set neighbors = page.fileSlug | lessonNeighbors %}
    {% if neighbors %}
    <nav class="lesson-pager" aria-label="Lesson navigation">
      {% if neighbors.prev %}<a class="lesson-pager-link lesson-pager-prev" href="/lessons/{{ neighbors.prev.slug }}/">&larr; Lesson {{ neighbors.prev.num }}</a>{% endif %}
      {% if neighbors.prev and neighbors.next %}<span class="lesson-pager-sep">&middot;</span>{% endif %}
      {% if neighbors.next %}<a class="lesson-pager-link lesson-pager-next" href="/lessons/{{ neighbors.next.slug }}/">Lesson {{ neighbors.next.num }} &rarr;</a>{% endif %}
    </nav>
    {% endif %}
  </main>
  <footer>
    <p>A self-study project.</p>
  </footer>
</body>
</html>
