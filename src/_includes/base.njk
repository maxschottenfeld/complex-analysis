<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Complex Analysis</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
  <script defer>
    document.addEventListener("DOMContentLoaded", function () {
      renderMathInElement(document.body, {
        delimiters: [
          { left: "$$", right: "$$", display: true },
          { left: "$", right: "$", display: false }
        ]
      });
    });
  </script>
</head>
<body>
  <nav class="site-nav">
    <a href="/">Complex Analysis</a>
    <a class="nav-link" href="/visualizations/">Visualizations</a>
  </nav>
  <main{% if wide %} class="wide"{% endif %}>
    {{ content | safe }}
  </main>
  <footer>
    <p>A self-study project by Max Schottenfeld — lessons and visualizations built alongside Claude.</p>
  </footer>
</body>
</html>
