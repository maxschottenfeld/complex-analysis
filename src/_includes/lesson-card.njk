<a class="lesson-card" href="/lessons/{{ lesson.slug }}/" style="--h: {{ lesson.hue }}">
  <span class="lesson-num" aria-hidden="true">{{ lesson.num }}</span>
  <span class="lesson-card-body">
    <span class="lesson-card-title">Lesson {{ lesson.num }} — {{ lesson.title }}</span>
    <span class="lesson-card-desc">{{ lesson.description }}</span>
  </span>
  <span class="lesson-card-arrow" aria-hidden="true">&rarr;</span>
</a>
